      "variantStyles": { "Shape=Circle": { "width": 40, "height": 40, "radius": "full" }, "Shape=Line": { "width": 160, "height": 16 } },
      "props": [["className", "string", "\"\"", "Size + shape via className"]],
      "accessibility": { "keyboard": [["—", "Not interactive"]], "notes": ["aria-hidden on containers"] },
      "related": [{ "name": "Spinner", "desc": "Indeterminate loading." }]
