{
  "pageName": "Auth — Forgot Password",
  "root": {
    "type": "frame",
    "name": "Forgot Password / Default — Dark",
    "layout": "horizontal",
    "sizing": { "width": "fixed:1440", "height": "fixed:900" },
    "fill": "background",
    "children": [
      {
        "type": "frame",
        "name": "Left Panel — Branding",
        "layout": "vertical",
        "sizing": { "width": "fixed:720", "height": "fill" },
        "fill": "sidebar",
        "padding": "2xl",
        "gap": "xl",
        "align": { "justify": "space-between", "counter": "center" },
        "children": [
          {
            "type": "frame", "name": "Logo Row", "layout": "horizontal", "gap": "sm", "align": { "counter": "center" },
            "children": [
              { "type": "placeholder", "name": "Logo", "sizing": { "width": "fixed:28", "height": "fixed:28" }, "fill": "primary", "radius": "lg", "label": "◆" },
              { "type": "text", "content": "ShopPulse", "textStyle": "sp-h4", "fill": "sidebar-foreground" }
            ]
          },
          {
            "type": "placeholder",
            "name": "Dashboard Illustration",
            "sizing": { "width": "fixed:440", "height": "fixed:360" },
            "fill": "card", "fillOpacity": 0.06, "radius": "xl", "stroke": "primary",
            "label": "Dashboard Illustration (SVG)"
          },
          { "type": "text", "content": "© 2026 ShopPulse. All rights reserved.", "textStyle": "sp-caption", "fill": "muted-foreground" }
        ]
      },
      {
        "type": "frame",
        "name": "Right Panel — Form",
        "layout": "vertical",
        "sizing": { "width": "fill", "height": "fill" },
        "fill": "background",
        "align": { "justify": "center", "counter": "center" },
        "children": [
          {
            "type": "frame",
            "name": "Forgot Password Card",
            "layout": "vertical",
            "sizing": { "width": "fixed:440" },
            "fill": "card",
            "stroke": "border",
            "radius": "xl",
            "padding": "xl",
            "gap": "lg",
            "children": [
              {
                "type": "frame", "name": "Card Header", "layout": "vertical", "gap": "xs", "align": { "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "Forgot password?", "textStyle": "sp-h2", "fill": "foreground", "textAlign": "center" },
                  { "type": "text", "content": "Enter your email and we'll send you a reset link", "textStyle": "sp-body", "fill": "muted-foreground", "textAlign": "center" }
                ]
              },
              {
                "type": "frame", "name": "Form", "layout": "vertical", "gap": "md", "sizing": { "width": "fill" },
                "children": [
                  {
                    "type": "frame", "name": "Email Field", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Email", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Input", "name": "Email Input", "overrides": { "text": { "Input": "name@example.com" } }, "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "component", "componentSet": "Button", "name": "Send Reset Link",
                    "variants": { "Variant": "Default", "Size": "Default" },
                    "overrides": { "text": { "Label": "Send Reset Link" } },
                    "sizing": { "width": "fill" }
                  }
                ]
              },
              {
                "type": "frame", "name": "Back Link", "layout": "horizontal", "gap": "xs", "align": { "justify": "center", "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "← Back to sign in", "textStyle": "sp-body", "fill": "muted-foreground" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
