{
  "type": "foundation-components",
  "targetPage": "🧩 Components",
  "components": [
    {
      "name": "Select Trigger",
      "category": "Components / Form",
      "description": "Dropdown select trigger. 4 sizes, ChevronDown icon.",
      "properties": { "Size": ["lg", "default", "sm", "xs"], "State": ["Default", "Focus", "Error", "Disabled"] },
      "base": { "layout": "horizontal", "widthMode": "fixed", "width": 200, "height": 36, "paddingX": "sm", "paddingY": 0, "gap": "xs", "radius": "lg", "fill": "input", "stroke": "border", "textFill": "foreground", "textStyle": "SP/Body", "textContent": "Select option", "iconRight": true, "iconSize": 16 },
      "variantStyles": {
        "Size=lg": { "height": 40, "paddingX": "md", "gap": "sm" },
        "Size=sm": { "height": 32, "paddingX": "xs", "gap": "2xs" },
        "Size=xs": { "height": 32, "paddingX": "2xs", "gap": "3xs" },
        "State=Focus": { "stroke": "ring", "strokeWeight": 3 },
        "State=Error": { "stroke": "destructive-border" },
        "State=Disabled": { "opacity": 0.5 }
      },
      "props": [["size", "4 sizes", "\"default\"", "Height"], ["disabled", "boolean", "false", "Disable"], ["aria-invalid", "boolean", "false", "Error"]],
      "accessibility": { "keyboard": [["Tab", "Focus"], ["Enter/Space", "Open"], ["Arrow Up/Down", "Navigate"], ["Esc", "Close"]], "notes": ["Radix Select primitive"] },
      "related": [{ "name": "Combobox", "desc": "For searchable." }, { "name": "Input", "desc": "For free text." }]
    },
    {
      "name": "Textarea",
      "category": "Components / Form",
      "description": "Multi-line input. min-h 76px, p-xs, rounded-lg.",
      "properties": { "State": ["Default", "Focus", "Error", "Disabled"] },
      "base": { "layout": "vertical", "widthMode": "fixed", "width": 280, "height": 76, "paddingX": "xs", "paddingY": "xs", "radius": "lg", "fill": "input", "stroke": "border", "textFill": "muted-foreground", "textStyle": "SP/Body", "textContent": "Type your message..." },
      "variantStyles": {
        "State=Focus": { "stroke": "ring", "strokeWeight": 3 },
        "State=Error": { "stroke": "destructive-border" },
        "State=Disabled": { "opacity": 0.3 }
      },
      "props": [["placeholder", "string", "—", "Placeholder"], ["rows", "number", "3", "Visible rows"], ["disabled", "boolean", "false", "Disable"], ["aria-invalid", "boolean", "false", "Error"]],
      "accessibility": { "keyboard": [["Tab", "Focus"]], "notes": ["Pair with <Label>"] },
      "related": [{ "name": "Input", "desc": "Single-line." }]
    },
    {
      "name": "Radio",
      "category": "Components / Form",
      "description": "Radio button. 16×16px circle, rounded-full.",
      "properties": { "Value": ["Unchecked", "Checked"], "State": ["Default", "Focus", "Error", "Disabled"] },
      "base": { "layout": "horizontal", "widthMode": "fixed", "width": 16, "height": 16, "radius": "full", "fill": "input", "stroke": "border-strong", "hideLabel": true },
      "variantStyles": {
        "Value=Checked": { "fill": "primary", "stroke": "primary", "textFill": "primary-foreground" },
        "State=Focus": { "stroke": "ring", "strokeWeight": 3 },
        "State=Error": { "stroke": "destructive-border" },
        "State=Error,Value=Checked": { "fill": "destructive", "stroke": "destructive" },
        "State=Disabled": { "opacity": 0.5 }
      },
      "props": [["defaultValue", "string", "—", "Default selected"], ["disabled", "boolean", "false", "Disable all"], ["orientation", "\"horizontal\"|\"vertical\"", "\"vertical\"", "Layout"]],
      "accessibility": { "keyboard": [["Tab", "Focus group"], ["Arrow Up/Down", "Navigate"], ["Space", "Select"]], "notes": ["role=\"radiogroup\"", "aria-checked per item"] },
      "related": [{ "name": "Checkbox", "desc": "Multiple selection." }, { "name": "Select", "desc": "Dropdown." }]
