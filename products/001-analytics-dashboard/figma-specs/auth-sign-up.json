{
  "pageName": "Auth — Sign Up",
  "root": {
    "type": "frame",
    "name": "Sign Up / Default — Dark",
    "layout": "horizontal",
    "sizing": { "width": "fixed:1440", "height": "fixed:900" },
    "fill": "background",
    "children": [
      {
        "type": "frame",
        "name": "Left Panel — Branding",
        "layout": "vertical",
        "sizing": { "width": "fixed:720", "height": "fill" },
        "fill": "sidebar",
        "padding": "2xl",
        "gap": "xl",
        "align": { "justify": "space-between", "counter": "center" },
        "children": [
          {
            "type": "frame",
            "name": "Logo Row",
            "layout": "horizontal",
            "gap": "sm",
            "align": { "counter": "center" },
            "children": [
              { "type": "placeholder", "name": "Logo", "sizing": { "width": "fixed:28", "height": "fixed:28" }, "fill": "primary", "radius": "lg", "label": "◆" },
              { "type": "text", "content": "ShopPulse", "textStyle": "sp-h4", "fill": "sidebar-foreground" }
            ]
          },
          {
            "type": "placeholder",
            "name": "Dashboard Illustration",
            "sizing": { "width": "fixed:440", "height": "fixed:360" },
            "fill": "card",
            "fillOpacity": 0.06,
            "radius": "xl",
            "stroke": "primary",
            "label": "Dashboard Illustration (SVG)"
          },
          {
            "type": "frame",
            "name": "Stats Row",
            "layout": "horizontal",
            "gap": "xl",
            "align": { "counter": "center" },
            "children": [
              {
                "type": "frame", "layout": "vertical", "align": { "counter": "center" }, "gap": "3xs",
                "children": [
                  { "type": "text", "content": "10K+", "textStyle": "sp-h4", "fill": "sidebar-foreground" },
                  { "type": "text", "content": "Active Users", "textStyle": "sp-caption", "fill": "muted-foreground" }
                ]
              },
              { "type": "separator", "direction": "vertical" },
              {
                "type": "frame", "layout": "vertical", "align": { "counter": "center" }, "gap": "3xs",
                "children": [
                  { "type": "text", "content": "99.9%", "textStyle": "sp-h4", "fill": "sidebar-foreground" },
                  { "type": "text", "content": "Uptime", "textStyle": "sp-caption", "fill": "muted-foreground" }
                ]
              },
              { "type": "separator", "direction": "vertical" },
              {
                "type": "frame", "layout": "vertical", "align": { "counter": "center" }, "gap": "3xs",
                "children": [
                  { "type": "text", "content": "4.9★", "textStyle": "sp-h4", "fill": "sidebar-foreground" },
                  { "type": "text", "content": "Rating", "textStyle": "sp-caption", "fill": "muted-foreground" }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "frame",
        "name": "Right Panel — Form",
        "layout": "vertical",
        "sizing": { "width": "fill", "height": "fill" },
        "fill": "background",
        "align": { "justify": "center", "counter": "center" },
        "children": [
          {
            "type": "frame",
            "name": "Sign Up Card",
            "layout": "vertical",
            "sizing": { "width": "fixed:440" },
            "fill": "card",
            "stroke": "border",
            "radius": "xl",
            "padding": "xl",
            "gap": "lg",
            "children": [
              {
                "type": "frame",
                "name": "Card Header",
                "layout": "vertical",
                "gap": "xs",
                "align": { "counter": "center" },
                "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "Create an account", "textStyle": "sp-h2", "fill": "foreground", "textAlign": "center" },
                  { "type": "text", "content": "Get started with ShopPulse in minutes", "textStyle": "sp-body", "fill": "muted-foreground", "textAlign": "center" }
                ]
              },
              {
                "type": "frame",
                "name": "Form Fields",
                "layout": "vertical",
                "gap": "md",
                "sizing": { "width": "fill" },
                "children": [
                  {
                    "type": "frame", "name": "Name Field", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Full Name", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Input", "name": "Name Input", "overrides": { "text": { "Input": "Alex Rivera" } }, "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "frame", "name": "Email Field", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Email", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Input", "name": "Email Input", "overrides": { "text": { "Input": "name@example.com" } }, "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "frame", "name": "Password Field", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Password", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Input", "name": "Password Input", "overrides": { "text": { "Input": "Create a password" } }, "sizing": { "width": "fill" } },
                      {
                        "type": "frame", "name": "Password Strength", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                        "children": [
                          {
                            "type": "frame", "name": "Strength Bar Row", "layout": "horizontal", "gap": "xs", "sizing": { "width": "fill" }, "align": { "counter": "center" },
                            "children": [
                              { "type": "component", "componentSet": "Progress", "name": "Strength Bar", "sizing": { "width": "fill" } },
                              { "type": "text", "content": "Strong", "textStyle": "sp-caption", "fill": "primary" }
                            ]
                          },
                          {
                            "type": "frame", "name": "Requirements", "layout": "vertical", "gap": "3xs", "sizing": { "width": "fill" },
                            "children": [
                              { "type": "text", "content": "✓ At least 8 characters", "textStyle": "sp-caption", "fill": "foreground" },
                              { "type": "text", "content": "✓ One uppercase letter", "textStyle": "sp-caption", "fill": "foreground" },
                              { "type": "text", "content": "✓ One number", "textStyle": "sp-caption", "fill": "foreground" },
                              { "type": "text", "content": "✗ One special character", "textStyle": "sp-caption", "fill": "muted-foreground" }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "frame", "name": "Terms Row", "layout": "horizontal", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "component", "componentSet": "Checkbox", "name": "Terms Checkbox" },
                      { "type": "text", "content": "I agree to the Terms of Service and Privacy Policy", "textStyle": "sp-body", "fill": "foreground", "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "component", "componentSet": "Button", "name": "Create Account Button",
                    "variants": { "Variant": "Default", "Size": "Default" },
                    "overrides": { "text": { "Label": "Create Account" } },
                    "sizing": { "width": "fill" }
                  }
                ]
              },
              {
                "type": "frame", "name": "Divider", "layout": "horizontal", "gap": "md", "align": { "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "separator" },
                  { "type": "text", "content": "or continue with", "textStyle": "sp-caption", "fill": "muted-foreground" },
                  { "type": "separator" }
                ]
              },
              {
                "type": "frame", "name": "Social Buttons", "layout": "horizontal", "gap": "sm", "sizing": { "width": "fill" },
                "children": [
                  { "type": "component", "componentSet": "Button", "name": "Google", "variants": { "Variant": "Outline", "Size": "Default" }, "overrides": { "text": { "Label": "Google" } }, "sizing": { "width": "fill" } },
                  { "type": "component", "componentSet": "Button", "name": "GitHub", "variants": { "Variant": "Outline", "Size": "Default" }, "overrides": { "text": { "Label": "GitHub" } }, "sizing": { "width": "fill" } }
                ]
              },
              {
                "type": "frame", "name": "Footer", "layout": "horizontal", "gap": "3xs", "align": { "justify": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "Already have an account?", "textStyle": "sp-body", "fill": "muted-foreground" },
                  { "type": "text", "content": "Sign in", "textStyle": "sp-body-semibold", "fill": "primary" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
