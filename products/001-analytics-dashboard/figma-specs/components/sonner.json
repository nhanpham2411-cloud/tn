        { "token": "--spacing-md", "value": "16px", "description": "Horizontal padding (px-md)" },
        { "token": "--spacing-2xs", "value": "6px", "description": "Gap between icon, content, and action" },
        { "token": "--radius-lg", "value": "8px", "description": "Border radius (rounded-lg)" },
        { "token": "Shadows/lg", "value": "0 10px 15px -3px rgba(0,0,0,0.1)", "description": "Shadow effect style" }
      ],

      "bestPractices": [
        { "do": "Use toast for transient feedback after user actions (save, delete, send). It auto-dismisses.", "dont": "Use toast for persistent messages that require attention — use Alert instead." },
        { "do": "Keep toast content to 1-2 short lines. Title is mandatory, description is optional.", "dont": "Put paragraphs or complex instructions in a toast — use a Dialog or Sheet instead." },
        { "do": "Attach a single action (e.g. Undo) only when the action is immediately reversible.", "dont": "Put multiple actions or navigation links in a toast — it disappears too quickly." },
        { "do": "Match toast type to action result: success for completed, error for failed, warning for caution, info for neutral updates.", "dont": "Use default type for error feedback — users rely on semantic color + icon to quickly assess severity." }
      ],

