{
  "components": [
    {
      "name": "Sonner",
      "description": "Auto-dismissing toast notification for transient feedback. Inverted colors: bg-foreground text-background. Container: rounded-lg, border 1px foreground/90, py-sm px-md, shadow-lg. Icon (16px instance, semantic color) + Title (SP/Body Medium) + Description (SP/Caption) + Action button.",
      "category": "Feedback",
      "installation": {
        "dependencies": "pnpm add sonner",
        "import": "import { toast } from \"sonner\"\nimport { Toaster } from \"@/components/ui/sonner\"\n\n// Mount once at root:\n<Toaster />\n\n// Trigger anywhere:\ntoast(\"Event created\")\ntoast.success(\"Saved\")\ntoast.error(\"Failed\")"
      },

      "properties": {
        "Type": ["Default", "Success", "Error", "Warning", "Info"],
        "Show Description": ["Yes", "No"],
        "Show Action": ["Yes", "No"]
      },

      "base": {
        "layout": "horizontal",
        "primaryAlign": "start",
        "counterAlign": "center",
        "gap": "2xs",
        "width": 356,
        "heightMode": "hug",
        "radius": "lg",
        "fill": "foreground",
        "stroke": "toast-border",
        "strokeWidth": 1,
        "paddingX": "md",
        "paddingY": "sm",
        "effectStyleName": "Shadows/lg",
        "hideLabel": true,
        "children": [
          {
            "name": "Content",
            "type": "frame",
            "layout": "vertical",
            "primaryAlign": "start",
            "counterAlign": "start",
            "gap": "none",
            "paddingX": "none",
            "paddingY": "none",
            "heightMode": "hug",
            "fillWidth": true,
            "children": [
              { "name": "Title", "type": "text", "textStyle": "SP/Body Medium", "textContent": "Event created", "textFill": "background", "fillWidth": true },
              { "name": "Description", "type": "text", "textStyle": "SP/Caption", "textContent": "Monday, January 3rd at 6:00 PM", "textFill": "background", "fillWidth": true }
            ]
          },
          {
            "name": "Action",
            "type": "frame",
            "layout": "horizontal",
            "primaryAlign": "center",
            "counterAlign": "center",
            "paddingX": "sm",
            "paddingY": "2xs",
            "radius": "md",
            "fill": "background",
            "heightMode": "hug",
            "widthMode": "hug",
            "gap": "none",
            "children": [
              { "name": "Label", "type": "text", "textStyle": "SP/Label", "textContent": "Undo", "textFill": "foreground" }
            ]
          }
        ]
      },

