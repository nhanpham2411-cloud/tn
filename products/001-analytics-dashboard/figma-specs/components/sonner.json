        { "token": "--color-background", "value": "white / zinc-950", "description": "Toast text color (inverted)" },
        { "token": "--color-success", "value": "green-600 / green-500", "description": "Success icon color" },
        { "token": "--color-destructive", "value": "red-600 / red-500", "description": "Error icon color" },
        { "token": "--color-warning", "value": "amber-600 / amber-500", "description": "Warning icon color" },
        { "token": "--color-primary", "value": "violet-600 / violet-500", "description": "Info icon color" },
