      "props": [
        { "name": "toast()", "type": "function", "default": "—", "description": "Default toast — neutral feedback with no icon" },
        { "name": "toast.success()", "type": "function", "default": "—", "description": "Success feedback with CircleCheck icon" },
        { "name": "toast.error()", "type": "function", "default": "—", "description": "Error feedback with CircleAlert icon" },
        { "name": "toast.warning()", "type": "function", "default": "—", "description": "Warning feedback with TriangleAlert icon" },
        { "name": "toast.info()", "type": "function", "default": "—", "description": "Informational feedback with Info icon" },
        { "name": "description", "type": "string", "default": "undefined", "description": "Secondary line of text below the title" },
        { "name": "action", "type": "{ label: string; onClick: () => void }", "default": "undefined", "description": "Action button with label and click handler" },
        { "name": "duration", "type": "number", "default": "4000", "description": "Auto-dismiss duration in milliseconds" }
      ],

