{
  "components": [
    {
      "name": "Thumbnail",
      "description": "Visual element for product images, icon boxes, and text/initials badges. Three types: Image, Icon, Text. All types support Size, Shape, and Color properties.",
      "category": "Data Display",
      "installation": {
        "import": "import { Thumbnail } from \"@/components/ui/thumbnail\""
      },

      "properties": {
        "Type": ["Image", "Icon", "Text"],
        "Size": ["XS", "SM", "Default", "LG", "XL"],
        "Shape": ["Square", "Circle"],
        "Color": ["Default", "Primary", "Primary Solid", "Success", "Destructive", "Warning", "Outline", "Surface"]
      },

      "variantRestrictions": {
        "Type=Icon,Shape=Square": { "Size": ["XS", "SM", "Default", "LG"] },
        "Type=Image": { "Color": ["Default"] }
      },

      "base": {
        "layout": "horizontal",
        "primaryAlign": "center",
        "counterAlign": "center",
        "gap": "none",
        "paddingX": "none",
        "paddingY": "none",
        "width": 40,
        "height": 40,
        "heightMode": "fixed",
        "radius": "lg",
        "clipsContent": true,
        "fill": "muted",
        "hideLabel": true
      },

      "variantStyles": {
        "Type=Image": {
          "fill": "surface-raised",
          "stroke": "border",
          "imageUrl": "https://cdn.dummyjson.com/product-images/mobile-accessories/apple-airpods/1.webp"
        },
        "Type=Icon": {
          "clipsContent": false,
          "iconFill": "muted-foreground",
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Package", "iconSize": 18 }
          ]
        },
        "Type=Text": {
          "clipsContent": false,
          "textContent": "AB",
          "textFill": "muted-foreground",
          "textStyle": "SP/Body",
          "hideLabel": false
        },

        "Shape=Square": {},
        "Shape=Circle": { "radius": "full" },

        "Color=Default": {},
        "Color=Primary": { "fill": "primary-10", "textFill": "primary", "iconFill": "primary" },
        "Color=Primary Solid": { "fill": "primary", "textFill": "primary-foreground", "iconFill": "primary-foreground" },
        "Color=Success": { "fill": "success-subtle", "textFill": "success", "iconFill": "success" },
        "Color=Destructive": { "fill": "destructive-subtle", "textFill": "destructive", "iconFill": "destructive" },
        "Color=Warning": { "fill": "warning-subtle", "textFill": "warning", "iconFill": "warning" },
        "Color=Outline": { "fill": "outline-hover", "textFill": "muted-foreground", "iconFill": "muted-foreground" },
        "Color=Surface": { "fill": "surface-raised", "textFill": "muted-foreground", "iconFill": "muted-foreground" },

        "Type=Icon,Shape=Circle": {
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Star", "iconSize": 18 }
          ]
        },

        "Size=XS,Type=Image": { "width": 24, "height": 24 },
        "Size=SM,Type=Image": { "width": 32, "height": 32 },
        "Size=Default,Type=Image": {},
        "Size=LG,Type=Image": { "width": 48, "height": 48 },
        "Size=XL,Type=Image": {
          "width": 64, "height": 64,
          "imageUrl": "https://cdn.dummyjson.com/product-images/mens-watches/rolex-datejust/1.webp"
        },

        "Size=XS,Type=Image,Shape=Square": { "radius": "sm" },
        "Size=SM,Type=Image,Shape=Square": { "radius": "md" },

        "Size=XS,Type=Icon,Shape=Square": {
          "width": 24, "height": 24, "radius": "md",
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Globe", "iconSize": 12 }
          ]
        },
        "Size=SM,Type=Icon,Shape=Square": {
          "width": 28, "height": 28, "radius": "md",
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Globe", "iconSize": 14 }
          ]
        },
        "Size=Default,Type=Icon,Shape=Square": {
          "width": 36, "height": 36
        },
        "Size=LG,Type=Icon,Shape=Square": {
          "width": 44, "height": 44, "radius": "xl",
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Package", "iconSize": 20 }
          ]
        },

        "Size=XS,Type=Icon,Shape=Circle": {
          "width": 24, "height": 24,
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Star", "iconSize": 12 }
          ]
        },
        "Size=SM,Type=Icon,Shape=Circle": {
          "width": 28, "height": 28,
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "Star", "iconSize": 14 }
          ]
        },
        "Size=Default,Type=Icon,Shape=Circle": {},
        "Size=LG,Type=Icon,Shape=Circle": {
          "width": 48, "height": 48,
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "CircleCheck", "iconSize": 22 }
          ]
        },
        "Size=XL,Type=Icon,Shape=Circle": {
          "width": 64, "height": 64,
          "children": [
            { "type": "icon", "name": "Icon", "iconName": "CircleAlert", "iconSize": 24 }
          ]
        },

        "Size=XS,Type=Text": {
          "width": 24, "height": 24,
          "textContent": "1",
          "textStyle": "SP/Label"
        },
        "Size=SM,Type=Text": {
          "width": 28, "height": 28,
          "textContent": "AB",
          "textStyle": "SP/Label"
        },
        "Size=Default,Type=Text": {},
        "Size=LG,Type=Text": {
          "width": 48, "height": 48,
          "textContent": "JD",
          "textStyle": "SP/Body Medium"
        },
        "Size=XL,Type=Text": {
          "width": 64, "height": 64,
          "textContent": "BR",
          "textStyle": "SP/Heading 6"
        },

        "Size=XS,Type=Text,Shape=Square": { "radius": "md" },
        "Size=SM,Type=Text,Shape=Square": { "radius": "md" }
      },

