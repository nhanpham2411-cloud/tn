      "props": [
        { "name": "type", "type": "\"image\" | \"icon\" | \"text\"", "default": "image", "description": "Visual style — square image, icon box, or text badge" },
        { "name": "size", "type": "\"xs\" | \"sm\" | \"default\" | \"lg\" | \"xl\"", "default": "default", "description": "Size preset (varies per type and shape)" },
        { "name": "shape", "type": "\"square\" | \"circle\"", "default": "square (image/icon) / circle (text)", "description": "Shape — square (rounded corners) or circle. Image and Icon default to square, Text defaults to circle." },
        { "name": "color", "type": "\"default\" | \"primary\" | \"primary-solid\" | \"success\" | \"destructive\" | \"warning\" | \"outline\" | \"surface\"", "default": "default", "description": "Semantic color preset — controls background and icon/text color. Image type restricted to default only." },
        { "name": "src", "type": "string", "default": "—", "description": "Image source URL (Image type only)" },
        { "name": "alt", "type": "string", "default": "—", "description": "Accessible alt text (Image type only)" },
        { "name": "fallback", "type": "string", "default": "—", "description": "Fallback text when image fails or missing, 1-3 chars (Image type only)" },
        { "name": "icon", "type": "ReactNode", "default": "—", "description": "Icon element with size classes — color inherited from color prop via currentColor (Icon type only)" },
        { "name": "text", "type": "string | number", "default": "—", "description": "Text content — initials, numbers, 1-3 chars (Text type only)" },
        { "name": "className", "type": "string", "default": "—", "description": "Additional CSS classes" }
      ],

      "designTokens": [
        { "token": "--color-muted", "value": "zinc-100 / zinc-800", "description": "color=\"default\" background" },
        { "token": "--color-primary-10", "value": "violet-600/10", "description": "color=\"primary\" background (light)" },
        { "token": "--color-primary-20", "value": "violet-600/20", "description": "color=\"primary\" background (dark)" },
        { "token": "--color-primary", "value": "violet-600", "description": "color=\"primary-solid\" background" },
        { "token": "--color-success-subtle", "value": "green-50 / green-950", "description": "color=\"success\" background" },
        { "token": "--color-destructive-subtle", "value": "red-50 / red-950", "description": "color=\"destructive\" background" },
        { "token": "--color-warning-subtle", "value": "amber-50 / amber-950", "description": "color=\"warning\" background" },
        { "token": "--color-outline-hover", "value": "zinc-800/8 / white/8", "description": "color=\"outline\" background" },
        { "token": "--color-surface-raised", "value": "zinc-50 / zinc-900", "description": "color=\"surface\" background + Image type background" },
        { "token": "--color-muted-foreground", "value": "zinc-500 / zinc-400", "description": "Default icon/text foreground color" },
        { "token": "--color-primary-foreground", "value": "white", "description": "color=\"primary-solid\" foreground color" },
        { "token": "--color-success", "value": "green-600 / green-500", "description": "color=\"success\" foreground color" },
        { "token": "--color-destructive", "value": "red-600 / red-500", "description": "color=\"destructive\" foreground color" },
        { "token": "--color-warning", "value": "amber-600 / amber-500", "description": "color=\"warning\" foreground color" },
        { "token": "--color-border", "value": "zinc-200 / zinc-800", "description": "Image thumbnail ring border" }
      ],

      "bestPractices": [
        { "do": "Use Image type for product thumbnails with a short fallback string.", "dont": "Use Avatar for square product images — Avatar is circular, Thumbnail Image is square." },
        { "do": "Use Icon type with shape=\"square\" for status/category indicators in list rows.", "dont": "Hardcode icon box structure inline — use Thumbnail for consistency." },
        { "do": "Use Icon type with shape=\"circle\" for circular icon containers in KPI cards, empty states, and success/error modals.", "dont": "Manually create rounded-full div + icon inline — use Thumbnail Icon with shape=\"circle\" instead." },
        { "do": "Use Text type for step indicators, numbered badges, and initials.", "dont": "Create custom div + span for numbered circles — use Thumbnail Text instead." },
        { "do": "Use the color prop for semantic colors — color=\"primary\", color=\"success\", color=\"destructive\".", "dont": "Use className to set background colors — use the color prop instead for consistency." },
        { "do": "Use shape prop to control square vs circle — shape=\"square\" or shape=\"circle\".", "dont": "Use className for rounded-full — use shape=\"circle\" instead." }
      ],

