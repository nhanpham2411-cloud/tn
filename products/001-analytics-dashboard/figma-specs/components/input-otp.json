      "bestPractices": [
        { "do": "Use OTP Slot instances inside Input OTP for consistent styling.", "dont": "Create manual slot frames — always use the OTP Slot sub-component." },
        { "do": "Set Position=First on the first slot and Position=Last on the last slot.", "dont": "Use Middle position for edge slots — the rounded corners will be missing." }
