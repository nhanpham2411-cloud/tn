{
  "components": [
    {
      "name": "OTP Slot",
      "description": "Individual digit cell for Input OTP. 48×48px with border-y border-r border-border-strong (matching web CSS). Position determines corner radius and left border: First gets border-l + rounded-l-md, Last gets rounded-r-md. State controls content: empty, caret, digit, or disabled.",
      "category": "Form",
      "installation": {
        "dependencies": "pnpm add input-otp",
        "import": "import {\n  InputOTPSlot,\n} from \"@/components/ui/input-otp\""
      },

      "properties": {
        "Position": ["First", "Middle", "Last"],
        "State": ["Default", "Active", "Filled", "Disabled"]
      },

      "base": {
        "layout": "horizontal",
        "primaryAlign": "center",
        "counterAlign": "center",
        "width": 48,
        "height": 48,
        "widthMode": "fixed",
        "heightMode": "fixed",
        "gap": "none",
        "paddingX": "none",
        "paddingY": "none",
        "radius": "none",
        "fill": "background",
        "clipsContent": true,
        "stroke": "border-strong",
        "strokeSides": "top,right,bottom",
        "hideLabel": true,
        "children": [
          {
            "name": "Digit",
            "type": "text",
            "textStyle": "SP/Body",
            "textContent": "5",
            "textFill": "foreground",
            "showWhen": "State=Filled"
          },
          {
            "name": "Caret",
            "type": "frame",
            "width": 1,
            "height": 16,
            "widthMode": "fixed",
            "heightMode": "fixed",
            "fill": "foreground",
            "showWhen": "State=Active"
          }
        ]
      },

      "variantStyles": {
        "Position=First": { "strokeSides": "all", "radiusTopLeft": "md", "radiusBottomLeft": "md" },
        "Position=Last": { "radiusTopRight": "md", "radiusBottomRight": "md" },

        "State=Active": { "focusRing": "ring" },
        "State=Disabled": { "opacity": 0.5 },

        "Position=First,State=Active": { "strokeSides": "all", "radiusTopLeft": "md", "radiusBottomLeft": "md", "focusRing": "ring" },
        "Position=First,State=Disabled": { "strokeSides": "all", "radiusTopLeft": "md", "radiusBottomLeft": "md", "opacity": 0.5 },
        "Position=Last,State=Active": { "radiusTopRight": "md", "radiusBottomRight": "md", "focusRing": "ring" },
        "Position=Last,State=Disabled": { "radiusTopRight": "md", "radiusBottomRight": "md", "opacity": 0.5 }
      },

      "examples": [
        {
          "name": "Position Variants",
          "description": "First, middle, and last positions with rounded corners on edges.",
          "layout": "horizontal",
          "items": [
            { "label": "First", "props": { "Position": "First", "State": "Default" } },
            { "label": "Middle", "props": { "Position": "Middle", "State": "Default" } },
            { "label": "Last", "props": { "Position": "Last", "State": "Default" } }
          ]
        },
        {
          "name": "States",
          "description": "All interactive states for a middle-position slot.",
          "layout": "horizontal",
          "items": [
            { "label": "Default", "props": { "Position": "Middle", "State": "Default" } },
            { "label": "Active", "props": { "Position": "Middle", "State": "Active" } },
            { "label": "Filled", "props": { "Position": "Middle", "State": "Filled" } },
            { "label": "Disabled", "props": { "Position": "Middle", "State": "Disabled" } }
          ]
        }
      ],

      "props": [
        { "name": "index", "type": "number", "default": "--", "description": "Zero-based slot position within the OTP group (required)" },
        { "name": "className", "type": "string", "default": "\"\"", "description": "Additional CSS classes on the slot cell" }
      ],

      "designTokens": [
        { "token": "--color-border-strong", "value": "zinc-400 / zinc-600", "description": "Slot border color (border-y border-r, first gets border-l)" },
        { "token": "--color-ring", "value": "violet-600/30", "description": "Focus ring on active slot (3px)" },
        { "token": "--color-foreground", "value": "zinc-950 / zinc-50", "description": "Digit text and caret color" },
        { "token": "--size-3xl", "value": "48px", "description": "Slot dimensions (width and height)" },
