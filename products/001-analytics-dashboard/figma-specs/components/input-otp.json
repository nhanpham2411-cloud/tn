        { "figma": "State=Active", "value": "Focus ring + blinking caret", "code": "isActive", "codeValue": "ring-[3px] ring-ring + caret div" },
        { "figma": "State=Filled", "value": "Digit character visible", "code": "char", "codeValue": "Slot displays the entered digit" },
        { "figma": "State=Disabled", "value": "opacity-50", "code": "disabled", "codeValue": "Inherited from parent InputOTP disabled prop" }
