{
  "components": [
    {
      "name": "Alert",
      "description": "Inline feedback message for neutral, error, success, warning, and emphasis states. Non-interactive and static — use AlertDialog for confirmations. Container: rounded-lg, border 1px, py-sm px-md. Icon (16px instance) + Title (SP/Body Semibold) + Description (SP/Body).",
      "category": "Feedback",
      "installation": {
        "dependencies": "",
        "import": "import {\n  Alert,\n  AlertTitle,\n  AlertDescription,\n} from \"@/components/ui/alert\""
      },

      "properties": {
        "Type": ["Neutral", "Error", "Success", "Warning", "Emphasis"],
        "Show Icon": ["Yes", "No"],
        "Show Title": ["Yes", "No"],
        "Show Description": ["Yes", "No"],
        "In Card": ["Yes", "No"]
      },

      "variantRestrictions": {
        "Show Title=No": { "Show Description": ["Yes"] },
        "Show Description=No": { "Show Title": ["Yes"] }
      },

      "base": {
        "layout": "horizontal",
        "primaryAlign": "start",
        "counterAlign": "start",
        "gap": "sm",
        "width": 420,
        "heightMode": "hug",
        "radius": "lg",
        "stroke": "border",
        "strokeWidth": 1,
        "fill": "card",
        "paddingX": "md",
        "paddingY": "sm",
        "hideLabel": true,
        "children": [
          {
            "name": "Icon",
            "type": "instance",
            "component": "Icon / Info",
            "iconFill": "foreground",
            "width": 16,
            "height": 16,
            "widthMode": "fixed",
            "heightMode": "fixed"
          },
          {
            "name": "Content",
            "type": "frame",
            "layout": "vertical",
            "primaryAlign": "start",
            "counterAlign": "start",
            "gap": "none",
            "paddingX": "none",
            "paddingY": "none",
            "heightMode": "hug",
            "children": [
              {
                "name": "Title",
                "type": "text",
                "textStyle": "SP/Body Semibold",
                "textContent": "Heads up",
                "textFill": "foreground"
              },
              {
                "name": "Description",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Your settings will be applied on next login.",
                "textFill": "ghost-foreground"
              }
            ]
          }
        ]
      },

      "variantStyles": {
