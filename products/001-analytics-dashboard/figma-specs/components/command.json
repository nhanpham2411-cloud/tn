{
  "components": [
    {
      "name": "Command Item",
      "description": "A single selectable row inside a Command palette. Supports icon and shortcut variants with hover and disabled states.",
      "category": "Overlay",
      "installation": {
        "dependencies": "pnpm add cmdk",
        "import": "import {\n  Command, CommandInput, CommandList,\n  CommandEmpty, CommandGroup, CommandItem,\n  CommandShortcut, CommandSeparator\n} from \"@/components/ui/command\""
      },

      "properties": {
        "Type": ["Default", "With Icon", "With Shortcut"],
        "State": ["Default", "Hover", "Disabled"]
      },

      "base": {
        "layout": "horizontal",
        "width": 180,
        "height": 32,
        "primaryAlign": "start",
        "counterAlign": "center",
        "fill": "transparent",
        "radius": "sm",
        "paddingX": "xs",
        "paddingY": "2xs",
        "gap": "sm",
        "hideLabel": true,
        "children": [
          {
            "name": "Icon",
            "type": "frame",
            "width": 16,
            "height": 16,
            "fill": "foreground",
            "showWhen": "Type=With Icon"
          },
          {
            "name": "Label",
            "type": "text",
            "textStyle": "SP/Body",
            "textContent": "Profile",
            "textFill": "foreground",
            "fillWidth": true
          },
          {
            "name": "Shortcut",
            "type": "text",
            "textStyle": "SP/Mini",
            "textContent": "⌘A",
            "textFill": "muted-foreground",
            "showWhen": "Type=With Shortcut"
          }
        ]
      },

      "variantStyles": {
        "Type=Default": {},
        "Type=With Icon": {
          "children": [
            {
              "name": "Label",
              "textContent": "Analytics"
            }
          ]
        },
        "Type=With Shortcut": {
          "children": [
            {
              "name": "Label",
              "textContent": "Analytics"
            }
          ]
        },
        "State=Default": {},
        "State=Hover": {
          "fill": "muted"
        },
        "State=Disabled": {
          "opacity": 0.5
        }
      },

      "examples": [
        {
          "name": "Item Types",
          "description": "Available item variants for command palettes.",
          "layout": "vertical",
          "items": [
            { "label": "Default", "props": { "Type": "Default", "State": "Default" } },
            { "label": "With Icon", "props": { "Type": "With Icon", "State": "Default" } },
            { "label": "With Shortcut", "props": { "Type": "With Shortcut", "State": "Default" } }
          ]
        },
        {
          "name": "Item States",
          "description": "Interactive states for command items.",
          "layout": "vertical",
          "items": [
            { "label": "Default", "props": { "Type": "Default", "State": "Default" } },
            { "label": "Hover", "props": { "Type": "Default", "State": "Hover" } },
            { "label": "Disabled", "props": { "Type": "Default", "State": "Disabled" } }
          ]
        }
      ],

      "props": [
        { "name": "onSelect", "type": "(value: string) => void", "default": "—", "description": "Callback when item is selected via click or Enter" },
        { "name": "disabled", "type": "boolean", "default": "false", "description": "Removes item from keyboard navigation and greys it out" },
        { "name": "value", "type": "string", "default": "—", "description": "Override the search matching value (defaults to text content)" }
      ],

      "designTokens": [
        { "token": "--foreground", "value": "zinc-900 / zinc-50", "description": "Default item text + icon color" },
        { "token": "--muted", "value": "zinc-100 / zinc-800", "description": "Hover/selected background" },
        { "token": "--muted-foreground", "value": "zinc-500 / zinc-400", "description": "Shortcut text color" }
      ],

      "bestPractices": [
        { "do": "Use icons consistently — either all items in a group have icons or none.", "dont": "Mix icon and non-icon items within the same CommandGroup." },
        { "do": "Pair CommandShortcut with frequently-used actions only.", "dont": "Add shortcuts to every item — it creates visual noise." }
      ],

      "figmaMapping": [
        { "figma": "Item", "value": "px-xs py-2xs rounded-sm gap-sm", "code": "CommandItem", "codeValue": "px-xs py-2xs rounded-sm typo-paragraph-sm gap-2" },
        { "figma": "State=Hover", "value": "bg-muted", "code": "data-[selected=true]", "codeValue": "bg-muted text-foreground" },
        { "figma": "Shortcut", "value": "SP/Mini, muted-foreground", "code": "CommandShortcut", "codeValue": "ml-auto typo-paragraph-mini text-muted-foreground" }
      ],

      "accessibility": {
        "keyboard": [
          { "key": "Enter", "action": "Select the currently highlighted item" },
          { "key": "Arrow Up/Down", "action": "Navigate between items" }
        ],
        "notes": [
          "Items have role within a listbox context",
          "Disabled items are excluded from keyboard navigation"
        ]
      },

      "related": [
        { "name": "Dropdown Menu", "desc": "For contextual action menus without search." },
        { "name": "Combobox", "desc": "For searchable single-value select fields." }
      ],

      "showcase": {
        "sections": ["header", "component", "installation"]
      }
    },

