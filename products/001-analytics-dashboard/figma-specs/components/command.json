{
  "components": [
    {
      "name": "Command",
      "description": "A searchable command palette for surfacing actions, navigation items, and settings. Supports keyboard navigation, item grouping, empty state, and per-item shortcut hints. Built on cmdk.",
      "category": "Overlay",
      "installation": {
        "dependencies": "pnpm add cmdk",
        "import": "import {\n  Command, CommandInput, CommandList,\n  CommandEmpty, CommandGroup, CommandItem,\n  CommandShortcut, CommandSeparator\n} from \"@/components/ui/command\""
      },

      "properties": {
        "Show Shortcuts": ["Yes", "No"]
      },

      "base": {
        "layout": "vertical",
        "width": 320,
        "fill": "card",
        "stroke": "border",
        "radius": "md",
        "effectStyleName": "Shadows/md",
        "paddingX": 0,
        "paddingY": 0,
        "gap": 0,
        "hideLabel": true,
        "children": [
          {
            "name": "Input Wrapper",
            "type": "frame",
            "layout": "horizontal",
            "counterAlign": "center",
            "height": 40,
            "heightMode": "fixed",
            "paddingX": "sm",
            "gap": "xs",
            "stroke": "border",
            "strokeSides": "bottom",
            "children": [
              {
                "name": "Search Icon",
                "type": "icon",
                "iconName": "Search",
                "iconSize": 16,
                "iconFill": "muted-foreground",
                "opacity": 0.5
              },
              {
                "name": "Placeholder",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Type a command or search...",
                "textFill": "muted-foreground",
                "fillWidth": true
              }
            ]
          },
          {
            "name": "Group 1",
            "type": "frame",
            "layout": "vertical",
            "paddingX": "3xs",
            "paddingY": "3xs",
            "gap": 0,
            "children": [
              {
                "name": "Heading 1",
                "type": "frame",
                "layout": "horizontal",
                "paddingX": "xs",
                "paddingY": "2xs",
                "children": [
                  {
                    "name": "Heading Text 1",
                    "type": "text",
                    "textStyle": "SP/Mini Medium",
                    "textContent": "Navigation",
                    "textFill": "muted-foreground"
                  }
                ]
              },
              {
                "name": "Item 1",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Analytics" },
                "iconOverrides": { "Icon": "BarChart3" },
                "fillWidth": true
              },
              {
                "name": "Item 2",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Profile" },
                "iconOverrides": { "Icon": "User" },
                "fillWidth": true
              },
              {
                "name": "Item 3",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Settings" },
                "iconOverrides": { "Icon": "Settings" },
                "fillWidth": true
              }
            ]
          },
          {
            "name": "Separator",
            "type": "divider",
            "fill": "border"
          },
          {
            "name": "Group 2",
            "type": "frame",
            "layout": "vertical",
            "paddingX": "3xs",
            "paddingY": "3xs",
            "gap": 0,
            "children": [
              {
                "name": "Heading 2",
                "type": "frame",
                "layout": "horizontal",
                "paddingX": "xs",
                "paddingY": "2xs",
                "children": [
                  {
                    "name": "Heading Text 2",
                    "type": "text",
                    "textStyle": "SP/Mini Medium",
                    "textContent": "Actions",
                    "textFill": "muted-foreground"
                  }
                ]
              },
              {
                "name": "Item 4",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "New Order" },
                "iconOverrides": { "Icon": "Plus" },
                "fillWidth": true
              },
              {
                "name": "Item 5",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Notifications" },
                "iconOverrides": { "Icon": "Bell" },
                "fillWidth": true
              }
            ]
          }
        ]
      },

      "variantStyles": {
        "Show Shortcuts=Yes": {},
        "Show Shortcuts=No": {}
      },

      "examples": [
        {
          "name": "Shortcut Visibility",
          "description": "Toggle keyboard shortcut hints on command items.",
          "layout": "horizontal",
          "items": [
            { "label": "With Shortcuts", "props": { "Show Shortcuts": "Yes" } },
            { "label": "Without Shortcuts", "props": { "Show Shortcuts": "No" } }
          ]
        }
      ],

      "props": [
        { "name": "value", "type": "string", "default": "—", "description": "Controlled search value" },
        { "name": "onValueChange", "type": "(value: string) => void", "default": "—", "description": "Callback fired on every keystroke" },
        { "name": "filter", "type": "(value: string, search: string) => number", "default": "—", "description": "Custom filter function (return 0 to hide, 1 to show)" },
        { "name": "loop", "type": "boolean", "default": "false", "description": "Wrap keyboard navigation at list boundaries" }
      ],

      "designTokens": [
        { "token": "--card", "value": "white / #252522", "description": "Command panel background" },
        { "token": "--border", "value": "zinc-200 / zinc-800", "description": "Panel border + separator + input border-b" },
        { "token": "--foreground", "value": "zinc-900 / zinc-50", "description": "Item text + icon color" },
        { "token": "--muted", "value": "zinc-100 / zinc-800", "description": "Selected/hover item background" },
        { "token": "--muted-foreground", "value": "zinc-500 / zinc-400", "description": "Group headings, placeholder, shortcut text" }
      ],

      "bestPractices": [
        { "do": "Use CommandDialog for the global command palette — trigger with a button or ⌘K shortcut.", "dont": "Leave the dialog open after an item is selected — dismiss immediately on select." },
        { "do": "Group related commands under meaningful headings (Navigation, Actions, Recent). Keep 4-6 items per group.", "dont": "Dump all commands into a single flat list without groups." },
        { "do": "Always include CommandEmpty — users need feedback when search has no matches.", "dont": "Skip the empty state — a blank list feels like a bug." }
      ],

      "figmaMapping": [
        { "figma": "Wrapper", "value": "bg-card, rounded-md, border", "code": "Command", "codeValue": "rounded-md bg-card text-foreground overflow-hidden" },
        { "figma": "Input", "value": "border-b, h-40, search icon opacity-50", "code": "CommandInput", "codeValue": "h-3xl border-b border-border px-sm typo-paragraph-sm" },
        { "figma": "Group heading", "value": "SP/Mini Medium, muted-foreground", "code": "[cmdk-group-heading]", "codeValue": "px-xs py-2xs typo-paragraph-mini-medium text-muted-foreground" },
        { "figma": "Separator", "value": "1px, border", "code": "CommandSeparator", "codeValue": "-mx-1 h-px bg-border" },
        { "figma": "Item", "value": "Dropdown Item instance", "code": "CommandItem", "codeValue": "px-xs py-2xs rounded-sm typo-paragraph-sm gap-2" },
        { "figma": "Empty", "value": "center, muted-foreground", "code": "CommandEmpty", "codeValue": "py-xl text-center typo-paragraph-sm" }
      ],

      "accessibility": {
        "keyboard": [
          { "key": "Arrow Up/Down", "action": "Navigate between selectable items" },
          { "key": "Enter", "action": "Select the currently highlighted item" },
          { "key": "Escape", "action": "Close CommandDialog or blur inline mode" },
          { "key": "⌘K (custom)", "action": "Open command palette via custom keydown listener" }
        ],
        "notes": [
          "Uses role='combobox' on input and role='listbox' on the list",
          "CommandDialog includes a visually hidden DialogTitle for screen readers",
          "Disabled items are automatically excluded from keyboard navigation",
          "Built on cmdk — not Radix"
        ]
      },

      "related": [
        { "name": "Combobox", "desc": "For searchable single-value select fields — use instead of Command for picking one value." },
        { "name": "Dialog", "desc": "CommandDialog wraps Command in a standard Dialog with overlay and focus trap." },
        { "name": "Dropdown Menu", "desc": "For contextual action menus — use instead of Command for simple lists without search." },
        { "name": "Popover", "desc": "Combine with inline Command for search-in-popover patterns (e.g. tag pickers)." }
      ],

      "showcase": {
        "sections": ["header", "component", "installation"]
      }
    }
  ]
}
