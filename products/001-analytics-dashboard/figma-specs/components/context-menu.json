{
  "components": [
    {
      "name": "Context Menu",
      "description": "A right-click triggered menu with keyboard navigation and typeahead. Use for contextual actions on elements like files, rows, or canvas areas.",
      "category": "Overlay",
      "installation": {
        "dependencies": "pnpm add @radix-ui/react-context-menu",
        "import": "import {\n  ContextMenu, ContextMenuTrigger, ContextMenuContent,\n  ContextMenuItem, ContextMenuSeparator, ContextMenuLabel,\n  ContextMenuShortcut\n} from \"@/components/ui/context-menu\""
      },

      "properties": {
        "Show Label": ["Yes", "No"],
        "Show Destructive": ["Yes", "No"]
      },

      "base": {
        "layout": "vertical",
        "width": 192,
        "fill": "card",
        "stroke": "border",
        "radius": "md",
        "effectStyleName": "Shadows/md",
        "paddingX": 0,
        "paddingY": 0,
        "gap": 0,
        "hideLabel": true,
        "children": [
          {
            "name": "Label Group",
            "type": "frame",
            "layout": "vertical",
            "paddingX": "3xs",
            "paddingY": "3xs",
            "gap": 0,
            "showWhen": "Show Label=Yes",
            "children": [
              {
                "name": "Label",
                "type": "frame",
                "layout": "horizontal",
                "paddingX": "xs",
                "paddingY": "2xs",
                "children": [
                  {
                    "name": "Text",
                    "type": "text",
                    "textStyle": "SP/Body Semibold",
                    "textContent": "file.tsx",
                    "textFill": "foreground"
                  }
                ]
              }
            ]
          },
          {
            "name": "Separator Top",
            "type": "divider",
            "fill": "border",
            "showWhen": "Show Label=Yes"
          },
          {
            "name": "Items Group",
            "type": "frame",
            "layout": "vertical",
            "paddingX": "3xs",
            "paddingY": "3xs",
            "gap": 0,
            "children": [
              {
                "name": "Item 1",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Open" },
                "iconOverrides": { "Icon": "Eye" },
                "fillWidth": true
              },
              {
                "name": "Item 2",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Rename" },
                "iconOverrides": { "Icon": "Pencil" },
                "fillWidth": true
              },
              {
                "name": "Item 3",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "With Icon", "State": "Default" },
                "textOverrides": { "Label": "Duplicate" },
                "iconOverrides": { "Icon": "Copy" },
                "fillWidth": true
              }
            ]
          },
          {
            "name": "Separator Bottom",
            "type": "divider",
            "fill": "border",
            "showWhen": "Show Destructive=Yes"
          },
          {
            "name": "Destructive Group",
            "type": "frame",
            "layout": "vertical",
            "paddingX": "3xs",
            "paddingY": "3xs",
            "gap": 0,
            "showWhen": "Show Destructive=Yes",
            "children": [
              {
                "name": "Destructive Item",
                "type": "instance",
                "component": "Dropdown Item",
                "variants": { "Type": "Destructive", "State": "Default" },
                "fillWidth": true
              }
            ]
          }
        ]
      },

      "variantStyles": {
        "Show Label=Yes": {},
        "Show Label=No": {},
        "Show Destructive=Yes": {},
        "Show Destructive=No": {}
      },

      "examples": [
        {
          "name": "Content Variants",
          "description": "Context menu with different content combinations.",
          "layout": "horizontal",
          "items": [
            { "label": "Full", "props": { "Show Label": "Yes", "Show Destructive": "Yes" } },
            { "label": "No Label", "props": { "Show Label": "No", "Show Destructive": "Yes" } },
            { "label": "Minimal", "props": { "Show Label": "No", "Show Destructive": "No" } }
          ]
        }
      ],

      "props": [
        { "name": "open", "type": "boolean", "default": "—", "description": "Controlled open state" },
        { "name": "onOpenChange", "type": "(open: boolean) => void", "default": "—", "description": "Callback when open changes" },
        { "name": "alignOffset", "type": "number", "default": "0", "description": "Offset from the anchor point" },
        { "name": "modal", "type": "boolean", "default": "true", "description": "Block interaction outside the menu" }
      ],

      "designTokens": [
        { "token": "--card", "value": "white / #252522", "description": "Menu background" },
        { "token": "--border", "value": "zinc-200 / zinc-800", "description": "Menu border + separator color" },
        { "token": "--foreground", "value": "zinc-900 / zinc-50", "description": "Label + item text color" },
        { "token": "--muted", "value": "zinc-100 / zinc-800", "description": "Item hover background" },
        { "token": "--muted-foreground", "value": "zinc-500 / zinc-400", "description": "Shortcut text color" },
        { "token": "--destructive", "value": "red-600", "description": "Destructive item text + icon" }
      ],

      "bestPractices": [
        { "do": "Use Context Menu for right-click actions on elements like files, rows, or canvas.", "dont": "Use Context Menu as the only way to access actions — always provide a visible alternative." },
        { "do": "Group related actions together with separators.", "dont": "Nest context menus more than one level deep." },
        { "do": "Place destructive actions at the bottom, separated from other items.", "dont": "Put too many items in one menu — consider sub-menus for 10+ items." }
      ],

      "figmaMapping": [
        { "figma": "Content", "value": "bg-card, border, shadow-md", "code": "ContextMenuContent", "codeValue": "min-w-[8rem] rounded-md border bg-card p-1 shadow-md" },
        { "figma": "Label", "value": "SP/Body Semibold, foreground", "code": "ContextMenuLabel", "codeValue": "px-xs py-2xs typo-paragraph-sm-bold text-foreground" },
        { "figma": "Separator", "value": "1px, border", "code": "ContextMenuSeparator", "codeValue": "-mx-1 my-1 h-px bg-border" },
        { "figma": "Item", "value": "Dropdown Item instance", "code": "ContextMenuItem", "codeValue": "flex items-center gap-2 px-xs py-2xs rounded-sm" },
        { "figma": "Animation", "value": "Zoom + Fade", "code": "data-[state]", "codeValue": "zoom-in-95 fade-in-0" }
      ],

      "accessibility": {
        "keyboard": [
          { "key": "Arrow Up/Down", "action": "Navigate between items" },
          { "key": "Enter / Space", "action": "Select the focused item" },
          { "key": "Escape", "action": "Close the context menu" },
          { "key": "Right Arrow", "action": "Open sub-menu (if present)" }
        ],
        "notes": [
          "Triggered by right-click or long-press on touch",
          "Focus is trapped inside the menu",
          "Typeahead search matches item text",
          "role=\"menu\" on ContextMenuContent"
        ]
      },

      "related": [
        { "name": "Dropdown Menu", "desc": "Click-triggered menu — use when a visible button trigger is preferred." },
        { "name": "Command", "desc": "Searchable command palette — use for large action/navigation lists." },
        { "name": "Popover", "desc": "Floating content panel — use for forms, not action lists." }
      ],

      "showcase": {
        "sections": ["header", "component", "installation"]
      }
    }
  ]
}
