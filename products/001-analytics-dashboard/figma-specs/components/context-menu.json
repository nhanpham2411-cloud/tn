              {
                "name": "Label 1",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Open",
                "textFill": "foreground"
              }
            ]
          },
          {
            "name": "Item 2",
            "type": "frame",
            "layout": "horizontal",
            "counterAlign": "center",
            "fillWidth": true,
            "height": 32,
            "radius": "sm",
            "paddingX": "xs",
            "paddingY": "2xs",
            "gap": "sm",
            "children": [
              {
                "name": "Icon 2",
                "type": "frame",
                "width": 16,
                "height": 16,
                "fill": "foreground",
                "showWhen": "Show Icons=Yes"
              },
              {
                "name": "Label 2",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Rename",
                "textFill": "foreground"
              }
            ]
          },
          {
            "name": "Item 3",
            "type": "frame",
            "layout": "horizontal",
            "counterAlign": "center",
            "fillWidth": true,
            "height": 32,
            "radius": "sm",
            "paddingX": "xs",
            "paddingY": "2xs",
            "gap": "sm",
            "children": [
              {
                "name": "Icon 3",
                "type": "frame",
                "width": 16,
                "height": 16,
                "fill": "foreground",
                "showWhen": "Show Icons=Yes"
              },
              {
                "name": "Label 3",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Duplicate",
                "textFill": "foreground"
              }
            ]
          },
          {
            "name": "Separator Bottom",
            "type": "frame",
            "fillWidth": true,
            "height": 1,
            "fill": "border",
            "showWhen": "Show Destructive=Yes"
          },
          {
            "name": "Destructive Item",
            "type": "frame",
            "layout": "horizontal",
            "counterAlign": "center",
            "fillWidth": true,
            "height": 32,
            "radius": "sm",
            "paddingX": "xs",
            "paddingY": "2xs",
            "gap": "sm",
            "showWhen": "Show Destructive=Yes",
            "children": [
              {
                "name": "Icon Delete",
                "type": "frame",
                "width": 16,
                "height": 16,
                "fill": "destructive",
                "showWhen": "Show Icons=Yes"
              },
              {
                "name": "Label Delete",
                "type": "text",
                "textStyle": "SP/Body",
                "textContent": "Delete",
                "textFill": "destructive"
              }
            ]
          }
        ]
      },

      "variantStyles": {
        "Show Label=Yes": {},
        "Show Label=No": {},
        "Show Icons=Yes": {},
        "Show Icons=No": {},
        "Show Separator=Yes": {},
        "Show Separator=No": {},
        "Show Destructive=Yes": {},
        "Show Destructive=No": {}
      },

      "examples": [
        {
          "name": "Content Variants",
          "description": "Context menu with different content combinations.",
          "layout": "horizontal",
          "items": [
            { "label": "Full", "props": { "Show Label": "Yes", "Show Icons": "Yes", "Show Separator": "Yes", "Show Destructive": "Yes" } },
            { "label": "No Icons", "props": { "Show Label": "Yes", "Show Icons": "No", "Show Separator": "Yes", "Show Destructive": "Yes" } },
            { "label": "Minimal", "props": { "Show Label": "No", "Show Icons": "No", "Show Separator": "No", "Show Destructive": "No" } }
          ]
        }
      ],

      "props": [
        { "name": "open", "type": "boolean", "default": "—", "description": "Controlled open state" },
        { "name": "onOpenChange", "type": "(open: boolean) => void", "default": "—", "description": "Callback when open changes" },
        { "name": "alignOffset", "type": "number", "default": "0", "description": "Offset from the anchor point" },
        { "name": "modal", "type": "boolean", "default": "true", "description": "Block interaction outside the menu" }
      ],

      "designTokens": [
        { "token": "--card", "value": "white / #252522", "description": "Menu background" },
        { "token": "--border", "value": "zinc-200 / zinc-800", "description": "Menu border + separator color" },
        { "token": "--foreground", "value": "zinc-900 / zinc-50", "description": "Label + item text color" },
        { "token": "--muted", "value": "zinc-100 / zinc-800", "description": "Item hover background" },
        { "token": "--muted-foreground", "value": "zinc-500 / zinc-400", "description": "Shortcut text color" },
        { "token": "--destructive", "value": "red-600", "description": "Destructive item text + icon" }
      ],

      "bestPractices": [
        { "do": "Use Context Menu for right-click actions on elements like files, rows, or canvas.", "dont": "Use Context Menu as the only way to access actions — always provide a visible alternative." },
        { "do": "Group related actions together with separators.", "dont": "Nest context menus more than one level deep." },
        { "do": "Place destructive actions at the bottom, separated from other items.", "dont": "Put too many items in one menu — consider sub-menus for 10+ items." }
      ],

      "figmaMapping": [
        { "figma": "Content", "value": "bg-card, border, shadow-md", "code": "ContextMenuContent", "codeValue": "w-48 rounded-md border bg-card p-1 shadow-md" },
        { "figma": "Label", "value": "SP/Body Semibold, foreground", "code": "ContextMenuLabel", "codeValue": "typo-paragraph-sm-bold text-foreground px-xs py-2xs" },
        { "figma": "Separator", "value": "1px, border", "code": "ContextMenuSeparator", "codeValue": "h-px bg-border" },
        { "figma": "Animation", "value": "Zoom + Fade", "code": "data-[state]", "codeValue": "zoom-in-95 fade-in-0" }
      ],

      "accessibility": {
        "keyboard": [
          { "key": "Arrow Up/Down", "action": "Navigate between items" },
          { "key": "Enter / Space", "action": "Select the focused item" },
          { "key": "Escape", "action": "Close the context menu" },
          { "key": "Right Arrow", "action": "Open sub-menu (if present)" }
        ],
        "notes": [
          "Triggered by right-click or long-press on touch",
          "Focus is trapped inside the menu",
          "Typeahead search matches item text",
          "role=\"menu\" on ContextMenuContent"
        ]
      },

      "related": [
        { "name": "Dropdown Menu", "desc": "Click-triggered menu — use when a visible button trigger is preferred." },
        { "name": "Command", "desc": "Searchable command palette — use for large action/navigation lists." },
        { "name": "Popover", "desc": "Floating content panel — use for forms, not action lists." }
      ],

      "showcase": {
        "sections": ["header", "component", "installation"]
      }
    }
  ]
}
