{
  "components": [
    {
      "name": "Calendar",
      "description": "A date picker calendar built on react-day-picker. Supports single date and date range selection with optional outside-day display. Uses Day Cell sub-component for individual day states.",
      "category": "Form",
      "installation": {
        "dependencies": "pnpm add react-day-picker date-fns",
        "import": "import { Calendar } from \"@/components/ui/calendar\""
      },

      "properties": {
        "Mode": ["Single", "Range"],
        "Show Outside Days": ["Yes", "No"]
      },

      "base": {
        "layout": "vertical",
        "width": 360,
        "fill": "card",
        "paddingX": "sm",
        "paddingY": "sm",
        "gap": 0,
        "hideLabel": true,
        "children": [
          {
            "name": "Nav",
            "type": "frame",
            "layout": "horizontal",
            "primaryAlign": "space-between",
            "counterAlign": "center",
            "fillWidth": true,
            "height": 32,
            "children": [
              {
                "name": "Prev",
                "type": "frame",
                "layout": "horizontal",
                "primaryAlign": "center",
                "counterAlign": "center",
                "width": 32,
                "height": 32,
                "radius": 8,
                "stroke": "border",
                "fill": "card",
                "children": [
                  {
                    "name": "Chevron Left",
                    "type": "frame",
                    "width": 18,
                    "height": 18,
                    "fill": "foreground"
                  }
                ]
              },
              {
                "name": "Month Title",
                "type": "text",
                "textStyle": "SP/Body Semibold",
                "textContent": "March 2026",
                "textFill": "foreground"
              },
              {
                "name": "Next",
                "type": "frame",
                "layout": "horizontal",
                "primaryAlign": "center",
                "counterAlign": "center",
                "width": 32,
                "height": 32,
                "radius": 8,
                "stroke": "border",
                "fill": "card",
                "children": [
                  {
                    "name": "Chevron Right",
                    "type": "frame",
                    "width": 18,
                    "height": 18,
                    "fill": "foreground"
                  }
                ]
              }
            ]
          },
          {
            "name": "Spacer Nav",
            "type": "frame",
            "fillWidth": true,
            "height": 16
          },
          {
            "name": "Weekdays",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "WD1", "type": "text", "textStyle": "SP/Mini", "textContent": "Su", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD2", "type": "text", "textStyle": "SP/Mini", "textContent": "Mo", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD3", "type": "text", "textStyle": "SP/Mini", "textContent": "Tu", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD4", "type": "text", "textStyle": "SP/Mini", "textContent": "We", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD5", "type": "text", "textStyle": "SP/Mini", "textContent": "Th", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD6", "type": "text", "textStyle": "SP/Mini", "textContent": "Fr", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" },
              { "name": "WD7", "type": "text", "textStyle": "SP/Mini", "textContent": "Sa", "textFill": "muted-foreground", "width": 48, "height": 32, "textAlign": "center" }
            ]
          },
          {
            "name": "Row 1",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "R1C1", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "1" } },
              { "name": "R1C2", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "2" } },
              { "name": "R1C3", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "3" } },
              { "name": "R1C4", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "4" } },
              { "name": "R1C5", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "5" } },
              { "name": "R1C6", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "6" } },
              { "name": "R1C7", "type": "instance", "component": "Day Cell", "variants": { "State": "Today" }, "textOverrides": { "Day": "7" } }
            ]
          },
          {
            "name": "Row 2",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "R2C1", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "8" } },
              { "name": "R2C2", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "9" } },
              { "name": "R2C3", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "10" } },
              { "name": "R2C4", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "11" } },
              { "name": "R2C5", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "12" } },
              { "name": "R2C6", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "13" } },
              { "name": "R2C7", "type": "instance", "component": "Day Cell", "variants": { "State": "Selected" }, "textOverrides": { "Day": "14" } }
            ]
          },
          {
            "name": "Row 3",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "R3C1", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "15" } },
              { "name": "R3C2", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "16" } },
              { "name": "R3C3", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "17" } },
              { "name": "R3C4", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "18" } },
              { "name": "R3C5", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "19" } },
              { "name": "R3C6", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "20" } },
              { "name": "R3C7", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "21" } }
            ]
          },
          {
            "name": "Row 4",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "R4C1", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "22" } },
              { "name": "R4C2", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "23" } },
              { "name": "R4C3", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "24" } },
              { "name": "R4C4", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "25" } },
              { "name": "R4C5", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "26" } },
              { "name": "R4C6", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "27" } },
              { "name": "R4C7", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "28" } }
            ]
          },
          {
            "name": "Row 5",
            "type": "frame",
            "layout": "horizontal",
            "fillWidth": true,
            "gap": 0,
            "children": [
              { "name": "R5C1", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "29" } },
              { "name": "R5C2", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "30" } },
              { "name": "R5C3", "type": "instance", "component": "Day Cell", "variants": { "State": "Default" }, "textOverrides": { "Day": "31" } },
              { "name": "R5C4", "type": "instance", "component": "Day Cell", "variants": { "State": "Outside" }, "textOverrides": { "Day": "1" }, "showWhen": "Show Outside Days=Yes" },
              { "name": "R5C5", "type": "instance", "component": "Day Cell", "variants": { "State": "Outside" }, "textOverrides": { "Day": "2" }, "showWhen": "Show Outside Days=Yes" },
              { "name": "R5C6", "type": "instance", "component": "Day Cell", "variants": { "State": "Outside" }, "textOverrides": { "Day": "3" }, "showWhen": "Show Outside Days=Yes" },
              { "name": "R5C7", "type": "instance", "component": "Day Cell", "variants": { "State": "Outside" }, "textOverrides": { "Day": "4" }, "showWhen": "Show Outside Days=Yes" }
            ]
          }
        ]
      },

      "variantStyles": {
        "Mode=Single": {},
        "Mode=Range": {
          "children": [
            { "name": "R2C3", "variants": { "State": "Range Start" } },
            { "name": "R2C4", "variants": { "State": "Range Middle" } },
            { "name": "R2C5", "variants": { "State": "Range Middle" } },
            { "name": "R2C6", "variants": { "State": "Range End" } },
            { "name": "R2C7", "variants": { "State": "Default" }, "textOverrides": { "Day": "14" } }
          ]
        },
        "Show Outside Days=Yes": {},
        "Show Outside Days=No": {}
      },

      "examples": [
        {
          "name": "Selection Modes",
          "description": "Single date and date range selection.",
          "layout": "horizontal",
          "items": [
            { "label": "Single", "props": { "Mode": "Single", "Show Outside Days": "Yes" } },
            { "label": "Range", "props": { "Mode": "Range", "Show Outside Days": "Yes" } }
          ]
        },
        {
          "name": "Outside Days",
          "description": "Toggle visibility of days from adjacent months.",
          "layout": "horizontal",
          "items": [
            { "label": "Shown", "props": { "Mode": "Single", "Show Outside Days": "Yes" } },
            { "label": "Hidden", "props": { "Mode": "Single", "Show Outside Days": "No" } }
          ]
        }
      ],

      "props": [
        { "name": "mode", "type": "\"single\" | \"range\"", "default": "\"single\"", "description": "Selection mode" },
        { "name": "selected", "type": "Date | DateRange", "default": "—", "description": "Selected date(s)" },
        { "name": "onSelect", "type": "(date) => void", "default": "—", "description": "Callback on selection" },
        { "name": "showOutsideDays", "type": "boolean", "default": "true", "description": "Show days from adjacent months" },
        { "name": "disabled", "type": "Date[] | Matcher", "default": "—", "description": "Dates to disable" },
        { "name": "numberOfMonths", "type": "number", "default": "1", "description": "Number of months to display (range mode uses 2)" }
      ],

      "designTokens": [
        { "token": "--card", "value": "white / #252522", "description": "Calendar background" },
        { "token": "--foreground", "value": "zinc-900 / zinc-50", "description": "Day text color" },
        { "token": "--primary", "value": "violet-600", "description": "Selected day background" },
        { "token": "--primary-foreground", "value": "white", "description": "Selected day text color" },
        { "token": "--ghost-hover", "value": "zinc-100 / zinc-800", "description": "Day hover background" },
        { "token": "--muted-foreground", "value": "zinc-500 / zinc-400", "description": "Weekday labels + outside day text" },
        { "token": "--border", "value": "zinc-200 / zinc-800", "description": "Calendar border + nav button border" }
      ],

      "bestPractices": [
        { "do": "Use Calendar inline when date selection is the primary task on the page.", "dont": "Use Calendar inline for quick date picking — use DatePicker with popover instead." },
        { "do": "Disable dates outside valid ranges with the disabled prop.", "dont": "Allow selection of invalid dates and validate later." },
        { "do": "Show outside days by default — it helps users understand the month context.", "dont": "Hide outside days when the calendar is used in a date range context." }
      ],

      "figmaMapping": [
        { "figma": "Calendar", "value": "p-sm, vertical layout", "code": "Calendar", "codeValue": "p-sm flex flex-col" },
        { "figma": "Nav buttons", "value": "32×32, outline, rounded-lg", "code": "button_previous/next", "codeValue": "size-2xl rounded-lg border p-[7px]" },
        { "figma": "Caption", "value": "SP/Body Semibold, center", "code": "caption_label", "codeValue": "typo-paragraph-sm font-semibold" },
        { "figma": "Weekday", "value": "48×32, SP/Mini, muted-fg", "code": "weekday", "codeValue": "w-[48px] h-[32px] text-[12px] text-muted-foreground" },
