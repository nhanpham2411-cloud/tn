{
  "pageName": "Auth — Onboarding",
  "root": {
    "type": "frame",
    "name": "Onboarding / Step 1 — Dark",
    "layout": "horizontal",
    "sizing": { "width": "fixed:1440", "height": "fixed:900" },
    "fill": "background",
    "children": [
      {
        "type": "frame",
        "name": "Left Panel — Branding",
        "layout": "vertical",
        "sizing": { "width": "fixed:720", "height": "fill" },
        "fill": "sidebar",
        "padding": "2xl",
        "gap": "xl",
        "align": { "justify": "space-between", "counter": "center" },
        "children": [
          {
            "type": "frame", "name": "Logo Row", "layout": "horizontal", "gap": "sm", "align": { "counter": "center" },
            "children": [
              { "type": "placeholder", "name": "Logo", "sizing": { "width": "fixed:28", "height": "fixed:28" }, "fill": "primary", "radius": "lg", "label": "◆" },
              { "type": "text", "content": "ShopPulse", "textStyle": "sp-h4", "fill": "sidebar-foreground" }
            ]
          },
          {
            "type": "placeholder",
            "name": "Dashboard Illustration",
            "sizing": { "width": "fixed:440", "height": "fixed:360" },
            "fill": "card", "fillOpacity": 0.06, "radius": "xl", "stroke": "primary",
            "label": "Dashboard Illustration (SVG)"
          },
          { "type": "text", "content": "© 2026 ShopPulse. All rights reserved.", "textStyle": "sp-caption", "fill": "muted-foreground" }
        ]
      },
      {
        "type": "frame",
        "name": "Right Panel — Onboarding",
        "layout": "vertical",
        "sizing": { "width": "fill", "height": "fill" },
        "fill": "background",
        "align": { "justify": "center", "counter": "center" },
        "children": [
          {
            "type": "frame",
            "name": "Onboarding Card",
            "layout": "vertical",
            "sizing": { "width": "fixed:480" },
            "fill": "card",
            "stroke": "border",
            "radius": "xl",
            "padding": "xl",
            "gap": "lg",
            "children": [
              {
                "type": "frame",
                "name": "Step Indicator",
                "layout": "horizontal",
                "gap": "xs",
                "align": { "counter": "center" },
                "sizing": { "width": "fill" },
                "children": [
                  {
                    "type": "frame", "name": "Step 1 Active",
                    "layout": "vertical",
                    "sizing": { "width": "fixed:28", "height": "fixed:28" },
                    "fill": "primary", "radius": "full",
                    "align": { "justify": "center", "counter": "center" },
                    "children": [
                      { "type": "text", "content": "1", "textStyle": "sp-caption", "fill": "primary-foreground" }
                    ]
                  },
                  {
                    "type": "frame", "name": "Connector 1",
                    "sizing": { "width": "fixed:20", "height": "fixed:2" },
                    "fill": "primary"
                  },
                  {
                    "type": "frame", "name": "Step 2 Inactive",
                    "layout": "vertical",
                    "sizing": { "width": "fixed:28", "height": "fixed:28" },
                    "fill": "muted", "radius": "full",
                    "align": { "justify": "center", "counter": "center" },
                    "children": [
                      { "type": "text", "content": "2", "textStyle": "sp-caption", "fill": "muted-foreground" }
                    ]
                  },
                  {
                    "type": "frame", "name": "Connector 2",
                    "sizing": { "width": "fixed:20", "height": "fixed:2" },
                    "fill": "muted"
                  },
                  {
                    "type": "frame", "name": "Step 3 Inactive",
                    "layout": "vertical",
                    "sizing": { "width": "fixed:28", "height": "fixed:28" },
                    "fill": "muted", "radius": "full",
                    "align": { "justify": "center", "counter": "center" },
                    "children": [
                      { "type": "text", "content": "3", "textStyle": "sp-caption", "fill": "muted-foreground" }
                    ]
                  }
                ]
              },
              { "type": "component", "componentSet": "Progress", "name": "Progress Bar", "sizing": { "width": "fill" } },
              {
                "type": "frame", "name": "Step Header", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "Company Info", "textStyle": "sp-h3", "fill": "foreground" },
                  { "type": "text", "content": "Tell us about your organization", "textStyle": "sp-body", "fill": "muted-foreground" }
                ]
              },
              {
                "type": "frame",
                "name": "Step 1 — Company Info",
                "layout": "vertical",
                "gap": "md",
                "sizing": { "width": "fill" },
                "children": [
                  {
                    "type": "frame", "name": "Company Name", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Company Name", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Input", "name": "Company Input", "overrides": { "text": { "Input": "Acme Inc." } }, "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "frame", "name": "Industry", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Industry", "textStyle": "sp-label", "fill": "foreground" },
                      { "type": "component", "componentSet": "Select", "name": "Industry Select", "overrides": { "text": { "Value": "Select your industry" } }, "sizing": { "width": "fill" } }
                    ]
                  },
                  {
                    "type": "frame", "name": "Team Size", "layout": "vertical", "gap": "xs", "sizing": { "width": "fill" },
                    "children": [
                      { "type": "text", "content": "Team Size", "textStyle": "sp-label", "fill": "foreground" },
                      {
                        "type": "frame", "name": "Radio Options", "layout": "horizontal", "gap": "md", "wrap": true,
                        "children": [
                          {
                            "type": "frame", "layout": "horizontal", "gap": "xs", "align": { "counter": "center" },
                            "children": [
                              { "type": "component", "componentSet": "Radio Group", "name": "Radio 1-10" },
                              { "type": "text", "content": "1-10", "textStyle": "sp-body", "fill": "foreground" }
                            ]
                          },
                          {
                            "type": "frame", "layout": "horizontal", "gap": "xs", "align": { "counter": "center" },
                            "children": [
                              { "type": "component", "componentSet": "Radio Group", "name": "Radio 11-50" },
                              { "type": "text", "content": "11-50", "textStyle": "sp-body", "fill": "foreground" }
                            ]
                          },
                          {
                            "type": "frame", "layout": "horizontal", "gap": "xs", "align": { "counter": "center" },
                            "children": [
                              { "type": "component", "componentSet": "Radio Group", "name": "Radio 51-200" },
                              { "type": "text", "content": "51-200", "textStyle": "sp-body", "fill": "foreground" }
                            ]
                          },
                          {
                            "type": "frame", "layout": "horizontal", "gap": "xs", "align": { "counter": "center" },
                            "children": [
                              { "type": "component", "componentSet": "Radio Group", "name": "Radio 200+" },
                              { "type": "text", "content": "200+", "textStyle": "sp-body", "fill": "foreground" }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "frame",
                "name": "Footer Buttons",
                "layout": "horizontal",
                "sizing": { "width": "fill" },
                "align": { "justify": "space-between" },
                "children": [
                  {
                    "type": "component", "componentSet": "Button", "name": "Back Button",
                    "variants": { "Variant": "Outline", "Size": "Default" },
                    "overrides": { "text": { "Label": "Back" } }
                  },
                  {
                    "type": "component", "componentSet": "Button", "name": "Continue Button",
                    "variants": { "Variant": "Default", "Size": "Default" },
                    "overrides": { "text": { "Label": "Continue" } }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
