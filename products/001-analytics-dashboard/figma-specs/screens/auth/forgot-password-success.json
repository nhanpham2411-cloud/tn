{
  "pageName": "Auth — Forgot Password Success",
  "root": {
    "type": "frame",
    "name": "Forgot Password / Email Sent — Dark",
    "layout": "horizontal",
    "sizing": { "width": "fixed:1440", "height": "fixed:900" },
    "fill": "background",
    "children": [
      {
        "type": "frame",
        "name": "Left Panel — Branding",
        "layout": "vertical",
        "sizing": { "width": "fixed:720", "height": "fill" },
        "fill": "sidebar",
        "padding": "2xl",
        "gap": "xl",
        "align": { "justify": "space-between", "counter": "center" },
        "children": [
          {
            "type": "frame", "name": "Logo Row", "layout": "horizontal", "gap": "sm", "align": { "counter": "center" },
            "children": [
              { "type": "placeholder", "name": "Logo", "sizing": { "width": "fixed:28", "height": "fixed:28" }, "fill": "primary", "radius": "lg", "label": "◆" },
              { "type": "text", "content": "ShopPulse", "textStyle": "sp-h4", "fill": "sidebar-foreground" }
            ]
          },
          {
            "type": "placeholder",
            "name": "Dashboard Illustration",
            "sizing": { "width": "fixed:440", "height": "fixed:360" },
            "fill": "card", "fillOpacity": 0.06, "radius": "xl", "stroke": "primary",
            "label": "Dashboard Illustration (SVG)"
          },
          { "type": "text", "content": "© 2026 ShopPulse. All rights reserved.", "textStyle": "sp-caption", "fill": "muted-foreground" }
        ]
      },
      {
        "type": "frame",
        "name": "Right Panel — Success",
        "layout": "vertical",
        "sizing": { "width": "fill", "height": "fill" },
        "fill": "background",
        "align": { "justify": "center", "counter": "center" },
        "children": [
          {
            "type": "frame",
            "name": "Success Card",
            "layout": "vertical",
            "sizing": { "width": "fixed:440" },
            "fill": "card",
            "stroke": "border",
            "radius": "xl",
            "padding": "xl",
            "gap": "lg",
            "children": [
              {
                "type": "frame", "name": "Success Icon", "layout": "vertical", "align": { "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  {
                    "type": "frame", "name": "Icon Circle",
                    "layout": "vertical",
                    "sizing": { "width": "fixed:48", "height": "fixed:48" },
                    "fill": "success",
                    "fillOpacity": 0.15,
                    "radius": "full",
                    "align": { "justify": "center", "counter": "center" },
                    "children": [
                      { "type": "text", "content": "✓", "textStyle": "sp-h3", "fill": "success" }
                    ]
                  }
                ]
              },
              {
                "type": "frame", "name": "Card Header", "layout": "vertical", "gap": "xs", "align": { "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "Check your email", "textStyle": "sp-h2", "fill": "foreground", "textAlign": "center" },
                  { "type": "text", "content": "We've sent a password reset link to name@example.com", "textStyle": "sp-body", "fill": "muted-foreground", "textAlign": "center" }
                ]
              },
              {
                "type": "component", "componentSet": "Button", "name": "Open Email Button",
                "variants": { "Variant": "Outline", "Size": "Default" },
                "overrides": { "text": { "Label": "Open Email App" } },
                "sizing": { "width": "fill" }
              },
              { "type": "text", "content": "Didn't receive the email? Check spam or try another email", "textStyle": "sp-caption", "fill": "muted-foreground", "textAlign": "center" },
              {
                "type": "frame", "name": "Back Link", "layout": "horizontal", "gap": "xs", "align": { "justify": "center", "counter": "center" }, "sizing": { "width": "fill" },
                "children": [
                  { "type": "text", "content": "← Back to sign in", "textStyle": "sp-body", "fill": "muted-foreground" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
