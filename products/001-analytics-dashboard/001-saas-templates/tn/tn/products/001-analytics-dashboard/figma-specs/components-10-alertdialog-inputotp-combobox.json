{
  "type": "foundation-components",
  "targetPage": "🧩 Components",
  "components": [
    {
      "name": "Alert Dialog Content",
      "category": "Components / Overlay",
      "description": "Blocking confirmation. max-w-lg, rounded-xl, p-xl gap-lg. Non-dismissible overlay. Cannot be closed by clicking outside.",
      "properties": {
        "ShowIcon": ["true", "false"],
        "ShowTitle": ["true", "false"],
        "ShowAction": ["true", "false"],
        "ShowActionSecondary": ["true", "false"]
      },
      "base": {
        "layout": "vertical", "widthMode": "fixed", "width": 480,
        "paddingX": "xl", "paddingY": "xl", "gap": "lg",
        "radius": "xl", "fill": "card", "stroke": "border",
        "textFill": "foreground", "textStyle": "SP/H4", "textContent": "Are you absolutely sure?"
      },
      "variantStyles": {},
      "props": [
        ["open", "boolean", "—", "Controlled open state"],
        ["onOpenChange", "(open: boolean) => void", "—", "Callback when open state changes"],
        ["defaultOpen", "boolean", "false", "Initial open state (uncontrolled)"],
        ["asChild", "boolean", "false", "AlertDialogTrigger — merge props onto child element"],
        ["container", "HTMLElement", "document.body", "AlertDialogPortal — portal target container"],
        ["forceMount", "boolean", "—", "AlertDialogContent — force mounting for animation libraries"],
        ["onOpenAutoFocus", "(e: Event) => void", "—", "AlertDialogContent — called on open auto-focus"],
        ["onCloseAutoFocus", "(e: Event) => void", "—", "AlertDialogContent — called on close auto-focus"],
        ["onEscapeKeyDown", "(e: KeyboardEvent) => void", "—", "AlertDialogContent — called on Escape key"],
        ["variant", "\"default\"|\"destructive\"|\"outline\"|\"secondary\"|\"ghost\"|\"link\"", "\"default\"", "AlertDialogAction — button visual variant"],
        ["size", "\"default\"|\"sm\"|\"lg\"|\"icon\"", "\"default\"", "AlertDialogAction/Cancel — button size"],
        ["className", "string", "—", "Additional CSS classes (all sub-components)"]
      ],
      "examples": [
        {
          "name": "Basic Confirmation",
          "description": "Standard alert with icon, title, description, and both action buttons.",
          "layout": "vertical",
          "items": [
            { "label": "Are you sure?", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } }
          ]
        },
        {
          "name": "Destructive",
          "description": "Destructive action confirmation — delete account, remove data permanently.",
          "layout": "vertical",
          "items": [
            { "label": "Delete Account", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } }
          ]
        },
        {
          "name": "Without Icon",
          "description": "Text-only confirmation without leading icon — simpler visual.",
          "layout": "vertical",
          "items": [
            { "label": "Discard Changes", "props": { "ShowIcon": "false", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } }
          ]
        },
        {
          "name": "Logout Confirmation",
          "description": "Session-ending action confirmation with Cancel and Log Out buttons.",
          "layout": "vertical",
          "items": [
            { "label": "Log Out", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } }
          ]
        },
        {
          "name": "Single Action (No Cancel)",
          "description": "Alert with only primary action — no secondary Cancel button.",
          "layout": "vertical",
          "items": [
            { "label": "Acknowledge", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "false" } }
          ]
        },
        {
          "name": "All Property Combinations",
          "description": "ShowIcon × ShowTitle × ShowAction × ShowActionSecondary key combinations.",
          "layout": "horizontal",
          "items": [
            { "label": "Full", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } },
            { "label": "No Icon", "props": { "ShowIcon": "false", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "true" } },
            { "label": "No Title", "props": { "ShowIcon": "true", "ShowTitle": "false", "ShowAction": "true", "ShowActionSecondary": "true" } },
            { "label": "Single Action", "props": { "ShowIcon": "true", "ShowTitle": "true", "ShowAction": "true", "ShowActionSecondary": "false" } }
          ]
        }
      ],
      "figmaMapping": [
        ["Overlay", "Black 50%", "AlertDialogOverlay", "bg-black/50, fixed inset-0, z-50"],
        ["Content", "bg-card, border, shadow", "AlertDialogContent", "max-w-lg, rounded-xl, p-xl, gap-lg"],
        ["Icon", "36px circle + icon", "—", "size-[36px] rounded-full border flex items-center justify-center"],
        ["Title", "heading 4", "AlertDialogTitle", "typo-heading-4 text-foreground"],
        ["Description", "paragraph small", "AlertDialogDescription", "typo-paragraph-sm text-muted-foreground"],
        ["Button Group", "flex, gap-xs", "AlertDialogFooter", "flex-col-reverse sm:flex-row sm:justify-end gap-xs"],
        ["Action", "Button default variant", "AlertDialogAction", "Wraps Radix in Button via asChild"],
        ["Cancel", "Button outline variant", "AlertDialogCancel", "Wraps Radix in Button via asChild"],
        ["ShowIcon", "true / false", "—", "Toggle leading icon circle visibility"],
        ["ShowTitle", "true / false", "—", "Toggle title text visibility"],
        ["ShowAction", "true / false", "—", "Toggle footer action buttons"],
        ["ShowActionSecondary", "true / false", "—", "Toggle Cancel button (requires ShowAction=true)"],
        ["Behavior", "Non-dismissible", "—", "Cannot close by clicking overlay (Radix default)"],
        ["Animation", "Open / Close", "data-state", "zoom-in-95 / zoom-out-95, fade-in / fade-out"],
        ["Variants", "Figma-only", "—", "Type Desktop/Mobile, Show Icon/Title/Action for design exploration"]
      ],
      "accessibility": {
        "keyboard": [
          ["Tab", "Move focus between action and cancel buttons"],
          ["Shift+Tab", "Move focus backwards between buttons"],
          ["Enter/Space", "Activate the focused button (action or cancel)"],
          ["Escape", "Close the dialog (same as cancel)"]
        ],
        "notes": [
          "Cannot dismiss by clicking overlay — users must take explicit action",
          "Focus trapped inside and auto-focused on first interactive element",
          "Focus returns to trigger element when closed",
          "role=\"alertdialog\" announces urgent content to screen readers",
          "aria-labelledby → AlertDialogTitle for dialog label",
          "aria-describedby → AlertDialogDescription for additional context",
          "Tab/Shift+Tab cycles only through dialog buttons"
        ]
      },
      "related": [
        { "name": "Dialog", "desc": "Dismissible modal for forms and interactions — can close by clicking outside." },
        { "name": "Sheet", "desc": "Slide-out panel for larger content areas." },
        { "name": "Drawer", "desc": "Bottom sheet for mobile-friendly interactions." },
        { "name": "Sonner (Toast)", "desc": "Transient non-blocking notifications — no user action required." }
      ]
    },
    {
      "name": "Input OTP Slot",
      "category": "Components / Form",
      "description": "OTP digit slot. size-3xl (40px), border-y + border-r, text-sm. Active: ring-[3px].",
      "properties": { "State": ["Empty", "Filled", "Active"], "Position": ["First", "Middle", "Last"] },
      "base": { "layout": "horizontal", "widthMode": "fixed", "width": 40, "height": 40, "paddingX": 0, "paddingY": 0, "fill": null, "stroke": "input", "textFill": "foreground", "textStyle": "SP/Body" },
      "variantStyles": {
        "State=Active": { "stroke": "ring", "strokeWeight": 3 },
        "Position=First": { "radius": "md" },
        "Position=Last": { "radius": "md" }
      },
      "props": [["maxLength", "number", "—", "Total digits (required)"], ["value", "string", "\"\"", "Controlled value"], ["onChange", "(value) => void", "—", "Input callback"]],
      "figmaMapping": [["Container", "—", "—", "flex items-center gap-xs"], ["Group", "—", "—", "flex items-center (no gap)"], ["Slot", "—", "—", "size-3xl border-y border-r"], ["First slot", "—", "—", "rounded-l-md border-l"], ["Last slot", "—", "—", "rounded-r-md"], ["Separator", "—", "—", "Minus icon between groups"]],
      "accessibility": { "keyboard": [["Tab", "Focus first slot"], ["0-9", "Enter digit"], ["Backspace", "Delete + back"], ["Ctrl+V", "Paste code"]], "notes": ["Auto-advance focus", "Paste support"] },
      "related": [{ "name": "Input", "desc": "Standard text." }]
    },
    {
      "name": "Combobox",
      "category": "Components / Form",
      "description": "Searchable dropdown. Button trigger w-[200px] outline, popover with command list.",
      "properties": { "State": ["Default", "Open", "Disabled"] },
      "base": { "layout": "horizontal", "widthMode": "fixed", "width": 200, "height": 36, "paddingX": "sm", "paddingY": 0, "gap": "xs", "radius": "lg", "fill": "card", "stroke": "border", "textFill": "foreground", "textStyle": "SP/Body", "textContent": "Select option...", "iconRight": true, "iconSize": 16 },
      "variantStyles": {
        "State=Open": { "stroke": "ring", "strokeWeight": 3 },
        "State=Disabled": { "opacity": 0.5 }
      },
      "props": [["options", "{ value, label }[]", "[]", "Options list"], ["value", "string", "\"\"", "Selected value"], ["onValueChange", "(v) => void", "—", "Selection callback"], ["placeholder", "string", "\"Select option...\"", "Trigger text"]],
      "accessibility": { "keyboard": [["Tab", "Focus trigger"], ["Enter/Space", "Open"], ["Arrow Up/Down", "Navigate"], ["Enter", "Select"], ["Esc", "Close"]], "notes": ["Type-ahead filtering"] },
      "related": [{ "name": "Select", "desc": "Non-searchable." }, { "name": "Input", "desc": "Free text." }]
    }
  ]
}
